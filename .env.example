# Kedin — example environment. Copy to `.env` and fill in YOUR values.
#   cp .env.example .env   &&   set -a && . ./.env && set +a
# Never commit your real .env or credentials/ — both are gitignored.

# ── LinkedIn ────────────────────────────────────────────────────────────────
# Path to your LinkedIn creds JSON (see credentials/linkedin/kedin.example.json).
# Holds client_id, client_secret, access_token, member_urn — seed it, then run `node oauth.js`.
KEDIN_CREDS=./credentials/linkedin/kedin.json
# OAuth redirect registered in your LinkedIn developer app.
KEDIN_REDIRECT=http://localhost:8765/callback
# LinkedIn API version. Bump ~yearly (probe /rest/me: 403=active, 426=retired).
LINKEDIN_VERSION=202605

# ── Workspace (runtime state; created on first use) ──────────────────────────
KEDIN_OUTBOX=./workspace/outbox.md
KEDIN_OUTBOX_IMAGE=./workspace/outbox-image.png
KEDIN_DIAGRAM_SRC=./workspace/outbox-diagram.mmd
KEDIN_LAST_POST=./workspace/last-post.json
# Media must be sent from an OpenClaw-allowed dir (not a workspace-* dir); staged here.
KEDIN_MEDIA_DIR=./workspace/media

# ── Chat delivery (OpenClaw `message send`) ──────────────────────────────────
# REQUIRED for send-image.sh / draft-diagram.sh: your chat id (e.g. Telegram numeric chat id).
KEDIN_TELEGRAM_TARGET=
# The OpenClaw channel account id your bot is registered under.
KEDIN_TELEGRAM_ACCOUNT=kedin

# ── Image generation ─────────────────────────────────────────────────────────
# Google Generative Language (Gemini) API key file for the diffusion image fallback.
GEMINI_KEY_FILE=./credentials/gemini/key
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# Optional: override the diffusion house-style prompt prefix (see gen-image.js).
# GEMINI_IMAGE_STYLE=

# ── Mermaid diagram renderer ─────────────────────────────────────────────────
# Theme for mermaid-cli (default|neutral|dark|forest). Chromium path is in mermaid-puppeteer.json.
KEDIN_MERMAID_THEME=default
