# Secrets & real config — NEVER commit
.env
credentials/*
!credentials/linkedin/
credentials/linkedin/*
!credentials/linkedin/*.example.json
!credentials/gemini/
credentials/gemini/*
!credentials/gemini/*.example.txt

# Runtime state / generated artifacts (keep the empty workspace dir)
workspace/*
